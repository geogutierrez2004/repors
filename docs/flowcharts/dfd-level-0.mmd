flowchart TB
  subgraph EXT[" External Entities "]
    U["👤 Users<br/>(Admin/Staff)"]
    SM["💾 External Storage<br/>(Backup/Restore)"]
  end
  
  subgraph SYS[" System Boundary - Electron Application "]
    RP["🖥️ Renderer Process<br/>(React UI)"]
    MP["⚙️ Main Process<br/>(Node.js Backend)"]
    DB[("📊 SQLite<br/>Database")]
    FS["💿 File Storage<br/>(Encrypted Payloads)"]
  end
  
  U -->|IPC: Login, File Ops<br/>Shelf/Org, Security Settings| RP
  RP -->|IPC Invoke| MP
  MP -->|Read/Write| DB
  MP -->|Read/Write| FS
  MP -->|Auth, File Data<br/>Activity Logs| RP
  RP -->|UI Display| U
  
  SM -->|Import Backup| MP
  MP -->|Export Backup| SM
  
  classDef external fill:#e1f5ff,stroke:#01579b,stroke-width:2px,color:#000
  classDef internal fill:#fff3e0,stroke:#e65100,stroke-width:2px,color:#000
  classDef storage fill:#e0f2f1,stroke:#00695c,stroke-width:2px,color:#000
  classDef boundary fill:#f3e5f5,stroke:#4a148c,stroke-width:2px
  
  class EXT external
  class RP,MP internal
  class DB,FS storage
  class SYS boundary