flowchart TD
    Start["🚀 App Start"] --> LoginPage["📝 Login Page"]
    
    LoginPage --> Input["Enter Username/Password"]
    Input --> Verify["PBKDF2 Verify"]
    Verify -->|Failed| InvalidCreds["❌ Invalid Credentials Error"]
    InvalidCreds --> LoginPage
    Verify -->|Success| CreateSession["✅ Create Session"]
    CreateSession --> Dashboard["🏠 Dashboard"]
    Dashboard --> NavBar["Navigation Bar<br/>🌙 Theme Toggle / 🚪 Logout"]
    Dashboard --> TabSelection{"Which Tab?"}
    
    TabSelection -->|1. OVERVIEW| Overview["📊 Overview Tab<br/>Dashboard Home"]
    TabSelection -->|2. FILES| FilesTab["📁 Files Tab"]
    TabSelection -->|3. ACTIVITY LOG| ActivityTab["📋 Activity Log Tab"]
    TabSelection -->|4. STORAGE & BACKUP| StorageTab["💾 Storage & Backup Tab"]
    TabSelection -->|5. SECURITY| SecurityTab["🔒 Security Tab"]
    TabSelection -->|6. USERS| AdminCheck{"Admin Only?"}
    
    AdminCheck -->|Staff| AccessDenied["🚫 Access Denied<br/>Return to Dashboard"]
    AccessDenied --> Dashboard
    AdminCheck -->|Admin| UsersTab["👥 Users Tab"]
    
    Overview --> DashHome["View Dashboard Overview"]
    DashHome --> Dashboard
    
    FilesTab --> FileOps{"File Operation?"}
    
    FileOps -->|Search| SearchFiles["🔍 Search Files<br/>Display Results"]
    SearchFiles --> FilesTab
    
    FileOps -->|Upload| UploadStart["📤 Upload Wizard"]
    UploadStart --> UploadMethod{"Upload Method?"}
    UploadMethod -->|Drag & Drop| SelectFiles["Select Files<br/>Batch or Single"]
    UploadMethod -->|Upload Button| SelectFiles
    SelectFiles --> KeepMove["📋 Modal:<br/>Keep Original OR<br/>Move to System?"]
    KeepMove --> Encrypt["🔐 Choose Encryption<br/>Level"]
    Encrypt --> UploadComplete["✅ Upload Complete"]
    UploadComplete --> FilesTab
    
    FileOps -->|Create Folder| CreateFolder["📁 Create Folder"]
    CreateFolder --> FilesTab
    
    FileOps -->|View Structure| ViewStructure["📂 View Folder Structure"]
    ViewStructure --> FilesTab
    
    FileOps -->|Select Files| SelectFilesAction["📋 Select Files<br/>Singular or All"]
    SelectFilesAction --> FilesTab
    
    FileOps -->|Download| DownloadFile["📥 Download Selected File"]
    DownloadFile --> FilesTab
    
    FileOps -->|Preview| PreviewFile["👁️ View File Temporarily<br/>Preview Mode"]
    PreviewFile --> FilesTab
    
    FileOps -->|Move| MoveFiles["🔀 Move Files to Other Folders"]
    MoveFiles --> FilesTab
    
    FileOps -->|Rename| RenameFiles["✏️ Rename Files"]
    RenameFiles --> FilesTab
    
    FileOps -->|Delete| DeleteCheck{"Admin Only?"}
    DeleteCheck -->|Staff| DeleteDenied["🚫 Delete Denied<br/>Permission Restricted"]
    DeleteDenied --> FilesTab
    DeleteCheck -->|Admin| DeleteConfirm["⚠️ Confirm Delete?"]
    DeleteConfirm -->|Yes| DeleteFiles["🗑️ Delete Files"]
    DeleteFiles --> FilesTab
    DeleteConfirm -->|No| FilesTab
    
    ActivityTab --> FilterDate["📅 Filter by Exact Dates"]
    FilterDate --> ShowActions["📋 Show Actions During<br/>Date Range"]
    ShowActions --> ExportChoice{"Export to CSV?"}
    ExportChoice -->|Yes| ExportCSV["💾 Export to CSV"]
    ExportCSV --> ActivityTab
    ExportChoice -->|No| ViewLog["📊 View Activity Log"]
    ViewLog --> ActivityTab
    
    StorageTab --> StorageOps{"Storage Action?"}
    
    StorageOps -->|View Quota| ViewQuota["📈 View Storage Quota<br/>Set by Admin"]
    ViewQuota --> ViewSizes["📊 View Current Folder Sizes"]
    ViewSizes --> StorageTab
    
    StorageOps -->|View Trend| ViewTrend["📈 View Storage Trend Chart"]
    ViewTrend --> StorageTab
    
    StorageOps -->|View Folders| ViewFolders["📂 View Individual Folders<br/>File Count / Size / % of Total"]
    ViewFolders --> StorageTab
    
    StorageOps -->|Backup| BackupClick["💾 Backup Button"]
    BackupClick --> BackupConfirm["📋 Confirmation Modal"]
    BackupConfirm -->|Yes| ExecuteBackup["💾 Execute Backup<br/>Export All Data"]
    ExecuteBackup --> BackupSuccess["✅ Backup Complete"]
    BackupSuccess --> StorageTab
    BackupConfirm -->|No| StorageTab
    
    StorageOps -->|Restore| RestoreClick["🔄 Restore Button"]
    RestoreClick --> RestoreConfirm["⚠️ Confirmation Modal<br/>WARNING: All current data<br/>will be replaced"]
    RestoreConfirm -->|Yes| SelectArchive["📂 Select Archive File"]
    SelectArchive --> ExecuteRestore["🔄 Execute Restore<br/>Verify & Extract"]
    ExecuteRestore --> RestoreSuccess["✅ Restore Complete<br/>Redirecting to Login"]
    RestoreSuccess --> LoginPage
    RestoreConfirm -->|No| StorageTab
    
    SecurityTab --> ViewStats["📊 View Security Stats:<br/>• Failed Uploads 24h & 7 days<br/>• Storage Risk %<br/>• Backup Freshness<br/>• Auth Threat Events<br/>• Auth Threat Activity by Hour<br/>• Critical Security Events"]
    ViewStats --> ModifyChoice{"Modify Thresholds?"}
    
    ModifyChoice -->|Yes| UpdateSettings["⚙️ Update Modifiable Thresholds:<br/>• Storage Warning %<br/>• Storage Danger %<br/>• Upload Failures Warning 24h<br/>• Upload Failures Danger 24h"]
    UpdateSettings --> SaveThresh["💾 Save Thresholds"]
    SaveThresh --> SecurityTab
    
    ModifyChoice -->|No| SecurityTab
    
    UsersTab --> UserOps{"Admin Operation?"}
    
    UserOps -->|Lock/Unlock| LockUnlock["🔒 Lock or Unlock Account"]
    LockUnlock --> UsersTab
    
    UserOps -->|Change Password| ChangePwd["🔐 Change User Password"]
    ChangePwd --> UsersTab
    
    UserOps -->|Delete Account| DeleteAccount["🗑️ Delete User Account"]
    DeleteAccount --> UsersTab
    
    UserOps -->|Make Inactive| MakeInactive["⏸️ Make User Inactive"]
    MakeInactive --> UsersTab
    
    UserOps -->|Add User| AddUser["👤 Add New User"]
    AddUser --> UsersTab
    
    UserOps -->|Change Own Password| OwnPwdFlow["🔐 Change Own Password<br/>2FA Required"]
    OwnPwdFlow --> EnterCurrent["Enter Current Password"]
    EnterCurrent --> ConfirmCurrent["Confirm Current Password"]
    ConfirmCurrent --> EnterNew["Enter New Password"]
    EnterNew --> PwdSuccess["✅ Password Updated Successfully"]
    PwdSuccess --> UsersTab
    
    NavBar -->|Theme| ThemeToggle["🌙 Toggle Dark/Light Mode"]
    ThemeToggle --> Dashboard
    
    NavBar -->|Logout| LogoutFlow["🚪 Logout<br/>Clear Session"]
    LogoutFlow --> LoginPage
    
    classDef start fill:#c8e6c9,stroke:#2e7d32,stroke-width:3px,color:#000
    classDef process fill:#fff3e0,stroke:#e65100,stroke-width:2px,color:#000
    classDef decision fill:#ffccbc,stroke:#d84315,stroke-width:2px,color:#000
    classDef error fill:#ffcdd2,stroke:#c62828,stroke-width:2px,color:#000
    classDef success fill:#c8e6c9,stroke:#388e3c,stroke-width:2px,color:#000
    classDef tab fill:#e1bee7,stroke:#6a1b9a,stroke-width:2px,color:#000
    
    class Start,Dashboard,UploadComplete,BackupSuccess,RestoreSuccess,PwdSuccess success
    class LoginPage,FilesTab,ActivityTab,StorageTab,SecurityTab,UsersTab tab
    class TabSelection,UploadMethod,FileOps,ExportChoice,StorageOps,ModifyChoice,UserOps,AdminCheck,DeleteCheck process
    class InvalidCreds,AccessDenied,DeleteDenied error
