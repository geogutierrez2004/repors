flowchart TD
  Start([🚀 App Start]) --> CheckSession{Session Valid?}
  
  CheckSession -->|No| Login["📝 Login Page"]
  Login --> InputCreds["Enter Username/Password"]
  InputCreds --> ValidateAuth{PBKDF2<br/>Verify}
  ValidateAuth -->|Failed| LoginError["❌ Error:<br/>Invalid Credentials"]
  LoginError --> Login
  ValidateAuth -->|Success| CreateSession["✅ Create Session<br/>Store Token"]
  CreateSession --> Dashboard["🏠 Dashboard"]
  
  CheckSession -->|Yes| Dashboard
  
  Dashboard --> NavTabs{Which Tab?}
  
  NavTabs -->|FILES| FileBrowser["📁 File Browser"]
  FileBrowser --> ShowShelves["Display Shelves<br/>(Exclude Archive/Inbox)"]
  ShowShelves --> FileAction{Select Action?}
  
  FileAction -->|View Files| DisplayFiles["📋 Show Files in Shelf"]
  DisplayFiles --> SelectFile{Select File?}
  SelectFile -->|Cancel| FileBrowser
  SelectFile -->|Download| DownloadFlow["📥 Download"]
  SelectFile -->|Preview| PreviewFlow["👁️ Preview"]
  SelectFile -->|Rename| RenameFlow["✏️ Rename"]
  SelectFile -->|Move| MoveFlow["🔀 Move"]
  SelectFile -->|Delete| DeleteFlow["🗑️ Delete"]
  
  FileAction -->|Upload| CheckRole{Admin or<br/>Staff?}
  CheckRole -->|No Session| Dashboard
  CheckRole -->|Admin| UploadAdmin["✅ Upload Allowed"]
  CheckRole -->|Staff| UploadStaff["✅ Upload Allowed"]
  UploadAdmin --> SelectUploadMethod
  UploadStaff --> SelectUploadMethod
  SelectUploadMethod{Upload Method?} -->|File Dialog| FileDialog["📂 Open File Dialog"]
  SelectUploadMethod -->|Drag-Drop| DragDrop["🎯 Show Drop Zone"]
  FileDialog --> SelectFiles["Select File(s)"]
  DragDrop --> SelectFiles
  SelectFiles --> CheckMultiple{Multiple?}
  CheckMultiple -->|Yes| BatchModal["📋 Show Batch Summary<br/>Confirm All Files"]
  CheckMultiple -->|No| CheckQuota
  BatchModal --> ConfirmBatch{Confirm?}
  ConfirmBatch -->|Cancel| FileBrowser
  ConfirmBatch -->|OK| CheckQuota{Quota<br/>Available?}
  CheckQuota -->|Exceeded| QuotaError["❌ Storage Full"]
  QuotaError --> FileBrowser
  CheckQuota -->|OK| SanitizeFilename["Sanitize Filename"]
  SanitizeFilename --> EncryptChoice{Encrypt?}
  EncryptChoice -->|No| StoreFile["Store to D3<br/>Plain"]
  EncryptChoice -->|Yes| GetPassword["🔐 Enter Password"]
  GetPassword --> ValidatePassPolicy{Password<br/>Policy Met?}
  ValidatePassPolicy -->|Failed| PassError["❌ Password Too Weak"]
  PassError --> GetPassword
  ValidatePassPolicy -->|OK| GenSalt["Generate Salt/IV"]
  GenSalt --> DeriveUploadKey["PBKDF2 Derive Key"]
  DeriveUploadKey --> EncryptFile["Encrypt AES-256-GCM"]
  EncryptFile --> StoreFile
  StoreFile --> LogActivity["Log Upload Activity"]
  LogActivity --> UploadComplete["✅ Upload Complete"]
  UploadComplete --> FileBrowser
  
  DownloadFlow --> SessionGuard1{Session Valid?}
  SessionGuard1 -->|No| SessionDenied["🚫 Session Invalid"]
  SessionDenied --> Login
  SessionGuard1 -->|Yes| GetFile["Fetch from D3"]
  GetFile --> IsEncrypted{Encrypted?}
  IsEncrypted -->|No| StreamFile["Stream Plain File"]
  IsEncrypted -->|Yes| PromptPass["🔐 Enter Password"]
  PromptPass --> DeriveKey["PBKDF2 Derive Key"]
  DeriveKey --> VerifyAuth["Verify Auth Tag"]
  VerifyAuth --> AuthOK{Auth Tag Valid?}
  AuthOK -->|Failed| DecryptError["❌ Decryption Failed"]
  DecryptError --> Dashboard
  AuthOK -->|Success| DecryptAES["Decrypt AES-256-GCM"]
  DecryptAES --> StreamFile
  StreamFile --> LogDownload["Log Download"]
  LogDownload --> Dashboard
  
  PreviewFlow --> SessionGuard2{Session Valid?}
  SessionGuard2 -->|No| SessionDenied
  SessionGuard2 -->|Yes| FetchEncrypted["Fetch File"]
  FetchEncrypted --> PreviewIsEncrypted{Encrypted?}
  PreviewIsEncrypted -->|No| PreviewPlain["Retrieve Plain"]
  PreviewIsEncrypted -->|Yes| PreviewPass["🔐 Enter Password"]
  PreviewPass --> PreviewDerive["PBKDF2 Derive Key"]
  PreviewDerive --> PreviewDecrypt["Decrypt AES-256-GCM"]
  PreviewDecrypt --> CreateTempFile["Write to D8<br/>Temp Files"]
  PreviewPlain --> CreateTempFile
  CreateTempFile --> InferMIME["Infer MIME Type"]
  InferMIME --> RenderType{File Type?}
  RenderType -->|PDF| PDFViewer["📄 PDF.js Viewer"]
  RenderType -->|Image| ImgViewer["🖼️ Image Viewer"]
  RenderType -->|DOCX| DocConverter["Mammoth<br/>→ HTML"]
  RenderType -->|XLSX| SheetConverter["read-excel-file<br/>→ Table"]
  RenderType -->|Text| TextViewer["📋 Text"]
  RenderType -->|Other| Fallback["⚠️ Download Link"]
  PDFViewer --> ShowPreview["🔒 Show Preview<br/>CSP-safe"]
  ImgViewer --> ShowPreview
  DocConverter --> ShowPreview
  SheetConverter --> ShowPreview
  TextViewer --> ShowPreview
  Fallback --> ShowPreview
  ShowPreview --> ScheduleDelete["Schedule Delete<br/>2min TTL"]
  ScheduleDelete --> LogPreview["Log Preview"]
  LogPreview --> Dashboard
  
  RenameFlow --> CheckRenameRole{Admin or<br/>Staff?}
  CheckRenameRole -->|No| RenameNotAllowed["🚫 Not Allowed"]
  RenameNotAllowed --> Dashboard
  CheckRenameRole -->|Yes| PromptNewName["Enter New Name"]
  PromptNewName --> SanitizeName["Sanitize Name"]
  SanitizeName --> UpdateMetadata["Update D2"]
  UpdateMetadata --> LogRename["Log Rename"]
  LogRename --> Dashboard
  
  MoveFlow --> CheckMoveRole{Admin or<br/>Staff?}
  CheckMoveRole -->|No| MoveNotAllowed["🚫 Not Allowed"]
  MoveNotAllowed --> Dashboard
  CheckMoveRole -->|Yes| SelectShelf["🗂️ Select Target Shelf"]
  SelectShelf --> UpdateShelf["Update D4"]
  UpdateShelf --> LogMove["Log Move"]
  LogMove --> Dashboard
  
  DeleteFlow --> CheckDeleteRole{Admin<br/>Only?}
  CheckDeleteRole -->|No| DeleteNotAllowed["🚫 Admin Only"]
  DeleteNotAllowed --> Dashboard
  CheckDeleteRole -->|Yes| ConfirmDelete["Confirm Delete?"]
  ConfirmDelete -->|Cancel| Dashboard
  ConfirmDelete -->|OK| DeleteFile["Remove from D3"]
  DeleteFile --> DeleteMetadata["Remove from D2"]
  DeleteMetadata --> LogDelete["Log Delete"]
  LogDelete --> Dashboard
  
  NavTabs -->|ACTIVITY LOG| ActivityLog["📊 Activity Log"]
  ActivityLog --> FilterActivity{Filter?}
  FilterActivity -->|By User| FilterUser["Select User"]
  FilterUser --> FilterDate["Select Date Range"]
  FilterDate --> DisplayActivity["📋 Display Filtered<br/>Auto-apply filter"]
  FilterActivity -->|By Type| FilterType["Select Operation"]
  FilterType --> FilterDate
  FilterActivity -->|None| DisplayActivity
  DisplayActivity --> ExportLog["💾 Export CSV"]
  ExportLog --> Dashboard
  
  NavTabs -->|SECURITY| SecurityDash["🔐 Security Dashboard"]
  SecurityDash --> ShowIntegrity["Integrity Stats<br/>(Read-only)"]
  ShowIntegrity --> ShowThresholds{Admin<br/>?}
  ShowThresholds -->|Yes| EditThresholds["⚙️ Edit Thresholds"]
  EditThresholds --> ApplyThresholds["Save Settings"]
  ApplyThresholds --> Dashboard
  ShowThresholds -->|No| Dashboard
  
  NavTabs -->|USERS| UserMgmt["👥 User Management"]
  UserMgmt --> ShowMyAccount["📌 My Account Card<br/>(Current User)"]
  ShowMyAccount --> ShowOtherUsers{Admin?}
  ShowOtherUsers -->|Yes| ListUsers["📋 List Other Users"]
  ListUsers --> UserOps{Action?}
  UserOps -->|Update Role| UpdateRole["Edit User Role"]
  UpdateRole --> SaveUser["Save Changes"]
  SaveUser --> UserMgmt
  UserOps -->|Change Pass| ChangePass["Enter Current Pass<br/>Twice (2FA)"]
  ChangePass --> ValidatePass{Passwords<br/>Match?}
  ValidatePass -->|No| PassMismatch["❌ Mismatch"]
  PassMismatch --> ChangePass
  ValidatePass -->|Yes| UpdatePass["Update in D1"]
  UpdatePass --> UserMgmt
  UserOps -->|Reset Pass| ResetPass["Send Reset Link"]
  ResetPass --> UserMgmt
  UserOps -->|Unlock| UnlockUser["Unlock Account"]
  UnlockUser --> UserMgmt
  ShowOtherUsers -->|No| Dashboard
  
  NavTabs -->|STORAGE| Storage["💾 Storage Management"]
  Storage --> ShowStats["📈 Show Storage Stats"]
  ShowStats --> ShowQuota{Admin?}
  ShowQuota -->|Yes| EditQuota["⚙️ Set Quota"]
  EditQuota --> SaveQuota["Save Quota"]
  SaveQuota --> BackupRestore
  ShowQuota -->|No| BackupRestore{Action?}
  BackupRestore -->|Backup| BackupClick["Click Backup"]
  BackupClick --> BackupModal["Confirmation Modal<br/>Backup will be<br/>exported to disk"]
  BackupModal --> ConfirmBackup{Confirm?}
  ConfirmBackup -->|Cancel| Storage
  ConfirmBackup -->|OK| ExecuteBackup["Export DB<br/>Archive Payloads<br/>Compress + Sign"]
  ExecuteBackup --> BackupComplete["✅ Backup Complete"]
  BackupComplete --> Storage
  BackupRestore -->|Restore| RestoreClick["Click Restore"]
  RestoreClick --> RestoreFile["Select Archive File"]
  RestoreFile --> RestoreModal["Confirmation Modal<br/>⚠️ WARNING:<br/>All current data<br/>will be replaced"]
  RestoreModal --> ConfirmRestore{Confirm?}
  ConfirmRestore -->|Cancel| Storage
  ConfirmRestore -->|OK| ExecuteRestore["Extract Archive<br/>Verify Signature<br/>Restore DB<br/>Hot-Swap Handlers<br/>Invalidate Sessions"]
  ExecuteRestore --> RestoreComplete["✅ Restore Complete<br/>Redirecting to Login"]
  RestoreComplete --> Login
  
